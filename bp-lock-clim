blueprint:
  name: Déverrouillage automatique du climatiseur
  description: Déverrouille l'automatisation quand la température est revenue dans les limites
  domain: automation
  input:
    temperature_entity:
      name: Capteur de température
      selector:
        entity:
          domain: input_number
    lock_entity:
      name: Verrou de l'automation
      selector:
        entity:
          domain: input_boolean
    target_temp:
      name: Température cible
      selector:
        entity:
          domain: input_number
    current_season:
      name: Saison actuelle
      selector:
        entity:
          domain: input_text
trigger:
  - platform: state
    entity_id: !input temperature_entity
condition:
  - condition: state
    entity_id: !input lock_entity
    state: 'on'
  - condition: or
    conditions:
      - condition: and
        conditions:
          - condition: numeric_state
            entity_id: !input temperature_entity
            below: !input target_temp
          - condition: or
            conditions:
              - condition: state
                entity_id: !input current_season
                state: "Hiver"
              - condition: state
                entity_id: !input current_season
                state: "Automne"
      - condition: and
        conditions:
          - condition: numeric_state
            entity_id: !input temperature_entity
            above: !input target_temp
          - condition: or
            conditions:
              - condition: state
                entity_id: !input current_season
                state: "Ete"
              - condition: state
                entity_id: !input current_season
                state: "Printemps"
action:
  - service: input_boolean.turn_off
    target:
      entity_id: !input lock_entity
