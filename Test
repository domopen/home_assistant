blueprint:
  name: GA - Climatisation - 
  description: Un blueprint pour ajuster automatiquement la climatisation en fonction de la température mesurée.
  domain: automation
  input:
    # --- Capteurs et paramètres de base ---
    temp_entity:
      name: Capteur de température
      description: Entité du capteur mesurant la température intérieure.
      selector:
        entity:
          domain: sensor
    ext_temp:
      name: Température extérieure
      description: Entité du capteur mesurant la température extérieure.
      selector:
        entity:
          domain: sensor
    clim_entity:
      name: Entité du climatiseur
      description: Entité de contrôle du climatiseur.
      selector:
        entity:
          domain: climate

    # --- Configuration des saisons ---
    current_season:
      name: Input text de la saison actuelle
      description: Indique la saison actuelle (Hiver, Automne, Printemps, Été).
      selector:
        entity:
          domain: input_text

    # --- Paramètres de température généraux ---
    temp_cible:
      name: Température cible
      description: Capteur indiquant la température souhaitée.
      selector: 
        entity: 
          domain: sensor
    min_temp:
      name: Température minimale tolérée
      description: Température en dessous de laquelle le chauffage se déclenche.
      selector:
        entity:
          domain: sensor
    max_temp:
      name: Température maximale tolérée
      description: Température au-dessus de laquelle le refroidissement se déclenche.
      selector:
        entity:
          domain: sensor

    # --- Mode Nuit ---
    nuit_semaine:
      name: Planning d'automatisation nuit en semaine
      description: Planning définissant les heures de mode nuit pour la semaine.
      selector:
        entity:
          domain: schedule
    nuit_weekend:
      name: Planning d'automatisation nuit en weekend
      description: Planning définissant les heures de mode nuit pour le weekend.
      selector:
        entity:
          domain: schedule
    temp_cible_nuit:
      name: Température de nuit
      description: Température cible pendant la nuit.
      selector:
        entity:
          domain: sensor
    min_temp_nuit:
      name: Température minimale tolérée la nuit
      description: Température minimale pendant les périodes de nuit.
      selector:
        entity:
          domain: sensor
    max_temp_nuit:
      name: Température maximale tolérée la nuit
      description: Température maximale pendant les périodes de nuit.
      selector:
        entity:
          domain: sensor

    # --- Mode Vacances ---
    vacation_mode:
      name: ON/OFF du mode vacances
      description: Active ou désactive le mode vacances (désactive les autres modes).
      selector:
        entity:
          domain: input_boolean
    min_temp_vacation:
      name: Température minimale tolérée en mode vacances
      description: Température minimale tolérée lorsque le mode vacances est activé.
      selector:
        entity:
          domain: sensor
    max_temp_vacation:
      name: Température maximale tolérée en mode vacances
      description: Température maximale tolérée lorsque le mode vacances est activé.
      selector:
        entity:
          domain: sensor

trigger:
  - platform: time_pattern
    minutes: "/15"
  - platform: state 
    entity_id: !input temp_cible
  - platform: state 
    entity_id: !input nuit_semaine
  - platform: state 
    entity_id: !input nuit_weekend
  - platform: state
    entity_id: !input vacation_mode

action:
  choose:
    # Mode Vacances (prioritaire)
    - conditions:
        - condition: state
          entity_id: !input vacation_mode
          state: "on"
      sequence:
        choose: 
          # Arrêt des clims si min < température actuelle > max
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input min_temp_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data: 
                  hvac_mode: "off"

          - conditions: 
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input max_temp_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data: 
                  hvac_mode: "off"

          # Démarre en dehors des conditions précédentes
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input max_temp_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data: 
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input min_temp_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data: 
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

    # Scénario Hiver/Automne
    - conditions:
        - condition: or
          conditions:
            - condition: state
              entity_id: !input current_season
              state: "Hiver"
            - condition: state
              entity_id: !input current_season
              state: "Automne"
        - condition: and
          conditions: 
            - condition: state
              entity_id: !input vacation_mode
              state: "off"
      sequence:
        choose:
          # Température actuelle supérieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input max_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: "off"

          # Température actuelle inférieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input min_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          # Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input max_temp
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input min_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle supérieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input max_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: "off"

          # Mode nuit - Température actuelle inférieures aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input max_temp_nuit
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

    # Scénario Été/Printemps
    - conditions:
        - condition: or
          conditions:
            - condition: state
              entity_id: !input current_season
              state: "Ete"
            - condition: state
              entity_id: !input current_season
              state: "Printemps"
        - condition: and
          conditions: 
            - condition: state
              entity_id: !input vacation_mode
              state: "off"
      sequence:
        choose:
          # Température actuelle supérieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input max_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          # Température actuelle inférieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input min_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: "off"

          # Température cible dans les tolérances 
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input max_temp
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input min_temp
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"
    
          # Mode nuit - Température actuelle inférieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: "off"

          # Mode nuit - Température actuelle superieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input max_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temp_entity
                below: !input max_temp_nuit
              - condition: numeric_state
                entity_id: !input temp_entity
                above: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input clim_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input clim_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input clim_entity
                data:
                  swing_mode: "vertical"

mode: single
