blueprint:
  name: Gestion automatique du climatiseur avec seuil de température
  description: Un blueprint pour ajuster automatiquement un climatiseur en fonction de la température mesurée.
  domain: automation
  input:
    temperature_entity:
      name: Capteur de température 
      selector:
        entity:
          domain: sensor
    climatiseur_entity:
      name: Entité du climatiseur
      selector:
        entity:
          domain: climate
    current_season:
      name: Input text de la saison actuelle
      selector:
        entity:
          domain: input_text
    schedule_nuit_semaine:
      name: Planning d'automatisation jour
      selector:
        entity:
          domain: schedule
    schedule_nuit_weekend:
      name: Planning d'automatisation night
      selector:
        entity:
          domain: schedule
    ext_temperature:
      name: Température extérieure
      selector:
        entity:
          domain: sensor
    temp_cible:
      name: Température cible
      selector: 
        entity: 
          domain: sensor
    min_temperature:
      name: Température minimale tolérée
      selector:
        entity:
          domain: sensor
    max_temperature:
      name: Température maximale tolérée 
      selector:
        entity:
          domain: sensor
    temp_cible_nuit:
      name: Température de nuit
      selector:
        entity:
          domain: sensor
    min_temp_nuit:
      name: Température minimale tolérée
      selector:
        entity:
          domain: sensor
    max_temp_nuit:
      name: Température maximale tolérée 
      selector:
        entity:
          domain: sensor
    vacation_mode:
      name: ON/OFF du mode vacances
      selector:
        entity:
          domain: input_boolean
    min_temperature_vacation:
      name: Température minimale tolérée en Mode Vacances
      selector:
        entity:
          domain: sensor
    max_temperature_vacation:
      name: Température minimale tolérée en Mode Vacances
      selector:
        entity:
          domain: sensor
    
trigger:
  - platform: time_pattern
    minutes: "/15"
  - platform: state 
    entity_id: !input temperature_cible
  - platform: state 
    entity_id: !input schedule_semaine_nuit
  - platform: state 
    entity_id: !input schedule_weekend_nuit
  - platform: state
    entity_id: !input vacation_mode

action:
  choose:
    # Mode Vacances (prioritaire)
    - conditions:
        - condition: state
          entity_id: !input vacation_mode
          state: "on"
      sequence:
        choose: 
          # Arrêt des climatiseurs si min < température actuelle > max
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input min_temperature_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data: 
                  hvac_mode: "off"

          - conditions: 
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input max_temperature_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data: 
                  hvac_mode: "off"

          # Démarre en dehors des conditions précédentes
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input max_temperature_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data: 
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input min_temperature_vacation
            sequence: 
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data: 
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

    # Scénario Hiver/Automne
    - conditions:
        - condition: or
          conditions:
            - condition: state
              entity_id: !input current_season
              state: "Hiver"
            - condition: state
              entity_id: !input current_season
              state: "Automne"
        - condition: and
          conditions: 
            - condition: state
              entity_id: !input vacation_mode
              state: "off"
      sequence:
        choose:
          # Température actuelle supérieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input max_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: "off"

          # Température actuelle inférieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input min_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          # Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input max_temperature
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input min_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle supérieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input schedule_nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input schedule_nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input max_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: "off"

          # Mode nuit - Température actuelle inférieures aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input schedule_nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input schedule_nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input temp_nuit_min
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input max_temp_nuit
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: heat
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

    # Scénario Été/Printemps
    - conditions:
        - condition: or
          conditions:
            - condition: state
              entity_id: !input current_season
              state: "Ete"
            - condition: state
              entity_id: !input current_season
              state: "Printemps"
        - condition: and
          conditions: 
            - condition: state
              entity_id: !input vacation_mode
              state: "off"
      sequence:
        choose:
          # Température actuelle supérieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input max_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          # Température actuelle inférieure à la tolérance
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input min_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: "off"

          # Température cible dans les tolérances 
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input max_temperature
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input min_temperature
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"
    
          # Mode nuit - Température actuelle inférieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input schedule_nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input schedule_nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input max_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: "off"

          # Mode nuit - Température actuelle superieure aux tolérances
          - conditions:
              - condition: or
                conditions:
                  - condition: state
                    entity_id: !input schedule_nuit_semaine
                    state: "on"
                  - condition: state
                    entity_id: !input schedule_nuit_weekend
                    state: "on"
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input temp_nuit_min
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "high"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

          # Mode nuit - Température actuelle dans les tolérances
          - conditions:
              - condition: numeric_state
                entity_id: !input temperature_entity
                below: !input max_temp_nuit
              - condition: numeric_state
                entity_id: !input temperature_entity
                above: !input min_temp_nuit
            sequence:
              - service: climate.set_hvac_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  hvac_mode: cool
              - service: climate.set_fan_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  fan_mode: "auto"
              - service: climate.set_swing_mode
                target:
                  entity_id: !input climatiseur_entity
                data:
                  swing_mode: "vertical"

mode: single
