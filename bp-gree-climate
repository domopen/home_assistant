blueprint:
  name: Gestion automatique du climatiseur avec seuil de température
  description: Un blueprint pour ajuster automatiquement un climatiseur en fonction de la température mesurée.
  domain: automation
  input:
    temperature_entity:
      name: Capteur de température 
      selector:
        entity:
          domain: input_number
    climatiseur_entity:
      name: Entité du climatiseur
      selector:
        entity:
          domain: climate
    current_season:
      name: Input text de la saison actuelle
      selector:
        entity:
          domain: input_text
    schedule_entity:
      name: Planning d'automatisation
      selector:
        entity:
          domain: schedule
    ext_temperature:
      name: Température extérieur
      selector:
        entity:
          domain: input_number
    temperature_cible:
      name: Température cible
      selector: 
        entity: 
          domain: input_number
    min_temperature:
      name: Température minimale tolérée
      selector:
        entity:
          domain: sensor
    max_temperature:
      name: Température maximale tolérée 
      selector:
        entity:
          domain: sensor
    lock_entity:
      name: Verrou de l'automation
      selector:
        entity:
          domain: input_boolean
          
trigger:
  - platform: state
    entity_id: !input temperature_entity
  - platform: state 
    entity_id: !input schedule_entity

condition:
  condition: state
  entity_id: !input lock_entity
  state: 'off'

action:
  - choose:
      # Scénario Hiver/Automne
      - conditions:
          - condition: or
            conditions:
              - condition: state
                entity_id: !input current_season
                state: "Hiver"
              - condition: state
                entity_id: !input current_season
                state: "Automne"
        sequence:
          - choose:
              # Condition : Si la température actuelle est supérieure à la tolérance et supérieur à la température extérieur
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  # Activer le verrou
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode chauffage et faible ventilation
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: heat
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "low"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "horizontal"
                  # Attendre avant de vérifier à nouveau la température
                  - delay: "00:05:00"
                  # Une seule vérification après le délai
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input max_temperature
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: "off"

              # Condition : Si la température actuelle est supérieure à la tolérance et inférieur à la température extérieur
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: "off"

              # Condition : Si la température actuelle est inférieure à la tolérance et supérieur à la température extérieur
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode chauffage automatique
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: heat
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

              # Condition : Si la température actuelle est inférieure à la tolérance et inférieur à la température extérieur
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode chauffage automatique
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: heat
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

              # Condition : Si la température cible est dans les tolérances et inférieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer chauffage + ventilation medium
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: heat
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

      # Scénario Été/printemps
      - conditions:
          - condition: or
            conditions:
              - condition: state
                entity_id: !input current_season
                state: "Ete"
              - condition: state
                entity_id: !input current_season
                state: "Printemps"
        sequence:
          - choose:
              # Condition : Si la température actuelle est supérieure à la tolérance et supérieur à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode climatisation et ventilation medium
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: cool
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

              # Condition : Si la température actuelle est supérieure à la tolérance et inférieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer climatisation et ventilation élevée
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: cool
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

              # Condition : Si la température actuelle est inférieure à la tolérance et supérieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode automatique
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: "auto"

              # Condition : Si la température actuelle est inférieure à la tolérance et inférieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer le mode automatique
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: "auto"

              # Condition : Si la température cible est dans les tolérances et inférieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Activer clim + ventilation medium
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: cool
                  - service: climate.set_fan_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      fan_mode: "auto"
                  - service: climate.set_swing_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      swing_mode: "vertical"

              # Condition : Si la température cible est dans les tolérances et supérieure à la température extérieure
              - conditions:
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    below: !input max_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input min_temperature
                  - condition: numeric_state
                    entity_id: !input temperature_entity
                    above: !input ext_temperature
                sequence:
                  - service: input_boolean.turn_on
                    target:
                      entity_id: !input lock_entity
                  # Désactiver la climatisation
                  - service: climate.set_hvac_mode
                    target:
                      entity_id: !input climatiseur_entity
                    data:
                      hvac_mode: "off"

mode: single
